{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user in the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique Firebase UID of the user." },
        "name": { "type": "string", "description": "The displayed name of the user." },
        "email": { "type": "string", "description": "The primary email address of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last updated timestamp." }
      },
      "required": ["id", "name", "email", "createdAt", "updatedAt"]
    },
    "Meeting": {
      "title": "Meeting Record",
      "description": "All details parsed and generated from a design or marketing system alignment meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the user who owns/created the alignment." },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "duration": { "type": "string" },
        "audioLengthSec": { "type": "integer" },
        "participants": { "type": "array" },
        "transcript": { "type": "string" },
        "summary": { "type": "object" },
        "tasks": { "type": "array" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed"] },
        "audioUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "date", "duration", "participants", "tasks", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Endpoint containing personal profile logs."
    },
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Primary meetings index scoped via relational ownerId attributes."
    }
  }
}
