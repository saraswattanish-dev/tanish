rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation schema fields constraints for User profiles
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 256
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Validation schema fields constraints for Meetings
    function isValidMeeting(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'date', 'duration', 'participants', 'tasks', 'status', 'createdAt', 'updatedAt'])
        && data.id is string && data.id.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.date is string && data.date.size() <= 32
        && data.duration is string && data.duration.size() <= 64
        && data.participants is list
        && data.tasks is list
        && (data.status == 'processing' || data.status == 'completed' || data.status == 'failed')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Collection: Users - Isolated private info
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUser(incoming())
        && incoming().id == userId
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().id == userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'updatedAt']);
    }

    // Collection: Meetings - Owned and accessible only by owner
    match /meetings/{meetingId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(meetingId)
        && isValidMeeting(incoming())
        && incoming().id == meetingId
        && incoming().ownerId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isValidId(meetingId)
        && existing().ownerId == request.auth.uid
        && incoming().ownerId == request.auth.uid
        && incoming().id == meetingId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidMeeting(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'title', 'status', 'participants', 'tasks', 'summary', 'transcript', 'updatedAt', 'audioUrl'
          ])
        );

      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
